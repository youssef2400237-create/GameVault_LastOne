<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Store - GameVault</title>
    <link rel="stylesheet" href="/styles/main.css" />
    <link rel="stylesheet" href="/styles/store.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  </head>
  <body>

    <%- include('partials/sidebar', { page: 'store' }) %>
    <%- include('partials/topnav', { breadcrumb: 'STORE' }) %>

    <main class="main-content">
      <section class="page-hero">
        <div class="page-hero-content">
          <div class="hero-label"><span class="label-tag" data-i18n="store-label">Take your world</span></div>
          <h1 class="page-title" data-i18n="store-title">Your Favorite Game: Red Dead Redemption 2</h1>
          <p class="page-description" data-i18n="store-desc">GameVault — take your own world and enjoy every moment.</p>
        </div>
      </section>

      <section class="trending-now">
        <div class="section-header">
          <h2 data-i18n="section-trending-now">Trending Now</h2>
          <a class="view-all" href="/trending" data-i18n="view-all-store">View All ></a>
        </div>
        <div class="products-grid-4">
          <% if (typeof games !== 'undefined' && games.length > 0) { %>
            <% games.forEach(function(game) { %>
              <div class="product-card game-card" data-game-id="<%= game._id %>">
                <div class="product-image">
                  <img src="<%= game.imageUrl || '/assets/rdr2-1280-1540463019272_160w.jpg' %>" alt="<%= game.title %>" />
                  <span class="price-tag">$<%= game.price.toFixed(2) %></span>
                </div>
                <div class="product-info">
                  <h3><%= game.title %></h3>
                  <div class="rating">★★★★★ (4.5)</div>
                </div>
                <button class="btn btn-small btn-primary">
                  <i class="fas fa-shopping-cart"></i> <span data-i18n="btn-add-cart">ADD TO CART</span>
                </button>
              </div>
            <% }) %>
          <% } else { %>
            <div class="product-card game-card">
              <div class="product-image"><img src="/assets/rdr2-1280-1540463019272_160w.jpg" alt="Red Dead Redemption 2" /><span class="price-tag">$59.99</span></div>
              <div class="product-info"><h3>Red Dead Redemption 2</h3><div class="rating">★★★★★ (4.5)</div></div>
              <button class="btn btn-small btn-primary"><i class="fas fa-shopping-cart"></i> <span data-i18n="btn-add-cart">ADD TO CART</span></button>
            </div>
            <div class="product-card game-card">
              <div class="product-image"><img src="/assets/maxresdefault.jpg" alt="EA Sports FC 26" /><span class="price-tag">$44.00</span></div>
              <div class="product-info"><h3>EA Sports FC 26</h3><div class="rating">★★★★☆ (4.4)</div></div>
              <button class="btn btn-small btn-primary"><i class="fas fa-shopping-cart"></i> <span data-i18n="btn-add-cart">ADD TO CART</span></button>
            </div>
            <div class="product-card game-card">
              <div class="product-image"><img src="/assets/1670549.jpg" alt="Grand Theft Auto V" /><span class="price-tag">$19.99</span></div>
              <div class="product-info"><h3>Grand Theft Auto V</h3><div class="rating">★★★★★ (4.8)</div></div>
              <button class="btn btn-small btn-primary"><i class="fas fa-shopping-cart"></i> <span data-i18n="btn-add-cart">ADD TO CART</span></button>
            </div>
            <div class="product-card game-card">
              <div class="product-image"><img src="/assets/22ac9450fc473af4a399876965972a5f.jpg" alt="Ghost Rider" /><span class="price-tag">$14.99</span></div>
              <div class="product-info"><h3>Ghost Rider</h3><div class="rating">★★★★☆ (4.3)</div></div>
              <button class="btn btn-small btn-primary"><i class="fas fa-shopping-cart"></i> <span data-i18n="btn-add-cart">ADD TO CART</span></button>
            </div>
          <% } %>
        </div>
      </section>

      <section class="library-section">
        <div class="section-header">
          <h2 data-i18n="section-library">Your Library is Waiting</h2>
          <button class="view-all" data-i18n="btn-browse-lib">BROWSE LIBRARY</button>
        </div>
        <div class="library-content">
          <div class="library-image"><img src="https://images.unsplash.com/photo-1552820728-8b83bb6b773f?w=600&h=400&fit=crop" alt="Library Showcase" /></div>
          <div class="library-info">
            <h3 data-i18n="library-title">Take Your Collection!</h3>
            <p data-i18n="library-desc">Access all your games across devices. Your progress, achievements, and friends list travel with you.</p>
            <button class="btn btn-primary"><i class="fas fa-book"></i> <span data-i18n="btn-browse2">BROWSE LIBRARY</span></button>
          </div>
        </div>
      </section>

      <section class="newsletter-section">
        <div class="newsletter-content">
          <h2 data-i18n="newsletter-store-title">Stay Updated</h2>
          <p data-i18n="newsletter-store-desc">Never miss a deal or new release. Subscribe for exclusive offers.</p>
          <div class="newsletter-form" id="newsletterFormStore">
            <input type="email" id="newsletterEmailStore" placeholder="Your email here..." class="newsletter-input" />
            <span class="newsletter-error" style="color:#ff006e;font-size:0.85rem;display:none;"></span>
            <button class="btn btn-primary" data-i18n="btn-subscribe">SUBSCRIBE</button>
          </div>
        </div>
      </section>

      <%- include('partials/footer') %>
    </main>

    <%- include('partials/cart-modal') %>

    <script src="/scriptes/main.js"></script>
    <script src="/scriptes/theme-lang.js"></script>
  </body>
</html>
